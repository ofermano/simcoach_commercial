# App
APP_NAME=Flow Simulation API
DEBUG=false

# Database (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flow_simulation

# JWT – use a long random string in production
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Super admin (used by migrations 002 and 003; username is always "admin")
# Set before first run for initial seed, or set and run migration 003 to update existing.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=admin

# SMTP (whitelist approval emails + super admin 6-digit login codes)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@flowsimulation.com 

# Frontend signup page – link in email will be: FRONTEND_SIGNUP_URL?token=...
FRONTEND_SIGNUP_URL=http://localhost:3000/signup
