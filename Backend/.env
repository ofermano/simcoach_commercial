# App
APP_NAME=Flow Simulation API
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/DBNAME

# JWT – use a long random string in production
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ISSUER=flow-simulation-api-beta
JWT_AUDIENCE=flow-simulation

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=GOOGLE-APP-ID
GOOGLE_CLIENT_SECRET=GOOGLE-APP-SECRET

# SMTP (whitelist approval emails + super admin 6-digit login codes)
# Super admin default after migration: username=admin, password=admin. Change in DB for production.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=add-here
SMTP_PASSWORD=add-here
MAIL_FROM=no-reply@flow.com

# Frontend signup page – link in email will be: FRONTEND_SIGNUP_URL?token=...
FRONTEND_SIGNUP_URL=http://localhost:5173/signup


# Super admin (used by migrations 002 and 003; username is always "admin")
# Set before first run for initial seed, or set and run migration 003 to update existing.
SUPER_ADMIN_EMAIL=EMAIL-HERE
SUPER_ADMIN_PASSWORD=PASSWORD-HERE
